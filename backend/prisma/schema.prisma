generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  role      Role       @default(USER)
  lostItems LostItem[]
  foundItems FoundItem[]
  claimRequests ClaimRequest[]
}

model LostItem {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  category    String
  location    String
  dateLost    DateTime
  reward      Float?
  imageUrl    String?
  status      ItemStatus @default(LOST)
  userId      Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
}

model FoundItem {
  id              Int        @id @default(autoincrement())
  title           String
  description     String
  category        String
  foundLocation   String
  dateFound       DateTime
  storageLocation String
  contactInfo     String
  imageUrl        String?
  status          ItemStatus @default(FOUND)
  userId          Int
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id])
  claimRequests   ClaimRequest[]
}

model ClaimRequest {
  id               Int         @id @default(autoincrement())
  proofOfOwnership String
  status           ClaimStatus @default(PENDING)
  foundItemId      Int
  claimantId       Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  foundItem        FoundItem   @relation(fields: [foundItemId], references: [id])
  claimant         User        @relation(fields: [claimantId], references: [id])

  @@unique([foundItemId, claimantId])
}

enum Role {
  USER
  ADMIN
}

enum ItemStatus {
  LOST
  FOUND
  CLAIMED
  RESOLVED
}

enum ClaimStatus {
  PENDING
  ACCEPTED
  REJECTED
}
